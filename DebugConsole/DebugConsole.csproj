<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net48</TargetFramework>
    <LangVersion>9.0</LangVersion>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <!-- DebugConsole generator sources are archived in the repo but are not needed to build or publish City Watchdog. -->
  <ItemGroup>
    <Compile Remove="Attributes\**\*.cs" />
    <Compile Remove="Extension\**\*.cs" />
    <Compile Remove="Localization\**\*.cs" />
    <Compile Remove="Notification\**\*.cs" />
  </ItemGroup>

  <ItemGroup>
    <None Include="Attributes\**\*.cs" />
    <None Include="Extension\**\*.cs" />
    <None Include="Localization\**\*.cs" />
    <None Include="Notification\**\*.cs" />
    <None Update="Localization\*.json">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
  </ItemGroup>

</Project>
